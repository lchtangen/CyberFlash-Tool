# Byte-compiled / optimized / DLL / cache files
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/
sdist/
wheels/

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE / editor
# VS Code — ignore personal settings, commit shared config
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# OS generated
.DS_Store
Thumbs.db
desktop.ini

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# mypy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# Ruff
.ruff_cache/

# Environments / secrets
.env
.env.*
*.pem
*.key

# Platform binaries (downloaded at runtime)
resources/tools/linux/*
resources/tools/macos/*
resources/tools/windows/*
!resources/tools/**/.gitkeep

# Packaging output
packaging/dist/
packaging/build/

# Jupyter
.ipynb_checkpoints/

# Logs
*.log
