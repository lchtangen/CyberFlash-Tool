{
  "codename": "shiba",
  "name": "Pixel 8",
  "brand": "Google",
  "model": "G9BQD",
  "model_variants": ["G9BQD", "GKWS6"],
  "chipset": "Tensor G3",
  "ab_slots": true,
  "bootloader": {
    "unlock_command": "fastboot flashing unlock",
    "requires_oem_unlock_menu": true,
    "warn_data_wipe": true
  },
  "flash": {
    "method": "fastboot",
    "partitions": [
      "boot",
      "dtbo",
      "init_boot",
      "product",
      "system",
      "system_ext",
      "vbmeta",
      "vbmeta_system",
      "vendor",
      "vendor_boot",
      "vendor_dlkm"
    ],
    "erase_partitions": [
      "boot",
      "dtbo",
      "init_boot",
      "vbmeta",
      "system",
      "vendor"
    ],
    "vbmeta_partition": "vbmeta",
    "vbmeta_disable_flags": "--disable-verity --disable-verification"
  },
  "recoveries": [
    {
      "name": "OrangeFox",
      "filename_pattern": "OrangeFox-*-shiba*.img",
      "flash_partition": "recovery"
    },
    {
      "name": "TWRP",
      "filename_pattern": "twrp-*-shiba*.img",
      "flash_partition": "recovery"
    }
  ],
  "wipe_partitions": {
    "dalvik": null,
    "cache": "cache",
    "data": "userdata",
    "system": "system",
    "vendor": "vendor"
  },
  "notes": "1. Enable 'OEM Unlocking' in Settings > Developer Options before unlocking bootloader.\n2. Use 'fastboot flashing unlock' (not 'oem unlock') for Pixel 8.\n3. Bootloader unlock WILL wipe all user data — back up first.\n4. Google Tensor G3 devices do not support EDL mode; EDL programmer is not available.\n5. The init_boot partition is separate from boot on Pixel 8 — both must be flashed for custom kernels."
}
