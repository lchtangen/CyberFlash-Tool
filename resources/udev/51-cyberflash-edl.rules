# CyberFlash — Qualcomm EDL (Emergency Download) USB access rule
# Allows non-root users to access the Qualcomm QDLoader 9008 interface.
# Install: sudo cp 51-cyberflash-edl.rules /etc/udev/rules.d/
# Reload:  sudo udevadm control --reload-rules && sudo udevadm trigger
SUBSYSTEM=="usb", ATTRS{idVendor}=="05c6", ATTRS{idProduct}=="9008", MODE="0666", TAG+="uaccess"
